# GitHub personal access token with repo read permissions
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub organization or user that owns the repositories
GITHUB_ORG=your-org-or-username

# Comma-separated list of repository names to monitor
GITHUB_REPOS=repo-one,repo-two

# Anthropic API key for Claude risk analysis
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
